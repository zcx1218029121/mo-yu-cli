{
  "name": "mo-yu-cli",
  "version": "1.0.0",
  "description": "🚀 在终端里光明正大地摸鱼",
  "homepage": "https://github.com/loaf/mo-yu-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/loaf/mo-yu-cli"
  },
  "main": "src/index.js",
  "bin": {
    "moYu": "./bin/moYu.js"
  },
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "assets": ["src/**/**"],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node bin/moYu.js",
    "test": "node --test tests/*.test.js",
    "lint": "echo \"Lint not configured yet\"",
    "prepublishOnly": "npm test"
  },
  "keywords": ["cli", "摸鱼", "mo-yu", "news", "terminal", "productivity"],
  "author": "loaf",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
